# sgChat Relay Server Configuration
# Copy this file to .env and fill in your values.

# --- Pairing Token ---
# Get this from the sgChat admin panel (Server Settings > Relay Servers > Add Relay).
# Only needed for the first startup — the relay saves its config after pairing.
RELAY_PAIRING_TOKEN=

# --- LiveKit Configuration ---
# These are YOUR relay's LiveKit credentials, NOT the Master server's.
# They must match the keys in your livekit-relay.yaml config file.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=your-relay-api-key
LIVEKIT_API_SECRET=your-relay-api-secret

# --- Relay Network Settings ---
# The port the relay service listens on (default: 3100)
RELAY_PORT=3100

# The public URL where Master can reach this relay's health endpoint.
# Must be accessible from the Master server's network.
# Example: http://your-server-ip:3100/health
RELAY_HEALTH_URL=http://YOUR_SERVER_IP:3100/health
